# Anotações pessoais de trabalho
prompt.md

# Configuração por máquina (documentada em .env.example)
.env

# Artefatos de build do ESP-IDF (regenerados por `make build`)
firmware/*/build/

# Backups antigos gerados pelo menuconfig
firmware/*/sdkconfig.old

# Componentes baixados pelo gerenciador do IDF (regenerados no build).
# O dependencies.lock fica VERSIONADO (reprodutibilidade, como package-lock).
firmware/*/managed_components/

# Site gerado pelo MkDocs (make docs-build)
site/

# Saidas regeneraveis do WireViz (o SVG e o YAML ficam versionados)
docs/wireviz/*.png
docs/wireviz/*.html
docs/wireviz/*.gv
docs/wireviz/*.tsv
docs/wireviz/*.tmp
