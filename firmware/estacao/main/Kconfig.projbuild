menu "Estacao - teste de bancada"

    choice ESTACAO_TESTE
        prompt "Qual teste rodar no boot"
        default ESTACAO_TESTE_TODOS
        help
            Seleciona o codigo que o app_main executa. Cada sensor tem
            um teste isolado; "todos" roda o autoteste de bancada e o
            loop de leitura continua de todos os sensores ja integrados.

        config ESTACAO_TESTE_TODOS
            bool "todos (modo bancada)"

        config ESTACAO_TESTE_LDR
            bool "LDR - luminosidade (GPIO 34, ADC)"

        config ESTACAO_TESTE_CHUVA
            bool "MH-RD - chuva (GPIO 35 AO + GPIO 27 DO)"

        config ESTACAO_TESTE_DHT11
            bool "DHT11 - umidade/temperatura (GPIO 4)"

        config ESTACAO_TESTE_VENTO
            bool "Reed-switch - vento (GPIO 25, interrupcao)"

        config ESTACAO_TESTE_LED
            bool "LED RGB - status (GPIOs 16/17/13, LEDC)"

    endchoice

endmenu
