# Overrides por máquina (copiar para .env — o .env fica fora do git).
# Qualquer variável do Makefile pode ser sobrescrita aqui.

# Porta serial da placa (típico no Arch: /dev/ttyUSB0 com CP2102/CH340)
#PORT=/dev/ttyUSB0

# Projeto padrão a compilar/gravar
#PROJ=firmware/estacao

# Versão da imagem do ESP-IDF (mudar exige repetir o make lsp-setup)
#IDF_VERSION=release-v5.3
